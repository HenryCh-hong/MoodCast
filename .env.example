# AI provider — pick one (or both; Anthropic takes priority)
# ANTHROPIC_API_KEY enables session generation + DJ chat (full experience)
ANTHROPIC_API_KEY=

# GOOGLE_API_KEY enables session generation only — DJ chat is not supported with this key
GOOGLE_API_KEY=

# Spotify (required for Spotify features; free account shows track list, Premium plays audio)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/auth/spotify/callback
