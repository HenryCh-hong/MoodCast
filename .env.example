# Moodcast — Environment Variables
# Copy this file to .env.local and fill in your values.

# ── Anthropic (BYOK) ────────────────────────────────────────────────────────
# Your Anthropic API key. Required for AI session generation.
# Without this, Moodcast runs in demo mode (5 prewritten sessions).
ANTHROPIC_API_KEY=

# ── Spotify ──────────────────────────────────────────────────────────────────
# Create your Spotify app at https://developer.spotify.com/dashboard
# Set "Redirect URI" to: http://localhost:3000/api/auth/spotify/callback
#
# IMPORTANT: These credentials are server-side only. Never use NEXT_PUBLIC_ prefix.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/auth/spotify/callback
