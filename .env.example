# AI provider — pick one (or both; Anthropic takes priority)
# ANTHROPIC_API_KEY enables session generation + DJ chat (full experience)
ANTHROPIC_API_KEY=

# GOOGLE_API_KEY enables session generation only — DJ chat is not supported with this key
GOOGLE_API_KEY=

# Spotify (required for Spotify features; free account shows track list, Premium plays audio)
# Moodcast uses Authorization Code with PKCE — only the Client ID is required.
# Do NOT set a client secret here: the PKCE flow does not use one, and shipping
# secrets in .env risks leaking them in deploys.
SPOTIFY_CLIENT_ID=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3001/api/auth/spotify/callback
